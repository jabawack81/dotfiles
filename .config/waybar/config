{
    "height": 40, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "modules-left": [
      "custom/launcher",
      "cpu",
      "memory",
      "custom/updates"
    ],
    "modules-center": [
      "wlr/workspaces",
      "custom/spotify"
    ],
    "modules-right": [
      "tray",
      "network",
      "pulseaudio",
      "pulseaudio#microphone",
      "bluetooth",
      "backlight",
      "battery",
      "custom/lock",
      "clock",
      "custom/power-menu"
    ],
    "wlr/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "active": " ≤░χψ",
            "default": "Ύηθ"
        }
    },
    "bluetooth": {
      "format": "<span color='#b4befe'>ΎΛΦ</span>",
      "format-disabled": "", // an empty format will hide the module
      "on-click": "bash ~/.config/waybar/scripts/rofi-bluetooth",
      "format-connected": "<span color='#b4befe'>ΎΛΦ</span> {num_connections} {device_battery_percentage}%",
      "tooltip-format": "{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}   {device_address}"
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 25
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%b %d %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 10,
        "format": "Ύαο {}%",
        "max-length": 10,
        "on-click": ""
    },
    "memory": {
        "interval": 30,
        "format": "Ύας {used:0.1f}GB",
        "format-alt": "Ύας {}%",
        "max-length": 10
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "tooltip-format": "{percent}",
        "format-icons": [
            "≤▒σΟ ",
            "≤▒σΠ ",
            "≤▒σΡ ",
            "≤▒σΣ ",
            "≤▒σΤ ",
            "≤▒σΥ ",
            "≤▒σΦ ",
            "≤▒σΧ ",
            "≤▒σΨ ",
            "≤░δρ "
        ]
    },
    "network": {
        /* "format-wifi": "Ύςρ", */
        "format-wifi": "{icon}",
        "format-ethernet": "Ύδ┐ ",
        "format-disconnected": "Ύςσ",
        "tooltip-format": "{essid}",
        "on-click": "~/.config/waybar/scripts/network/rofi-network-manager.sh",
        "format-icons": [
            "≤░νψ",
            "≤░νθ",
            "≤░νλ",
            "≤░νξ",
            "≤░νρ"
        ]
    },
    "custom/updates": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/updates",
        "on-click": "$HOME/.config/waybar/scripts/updates update",
        "interval": 300,
        "tooltip": true
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "ΎςΑ",
        "format-icons": {
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "Ύσ╜"
            ]
        },
        "on-click": "pavucontrol &"
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░",
        "format-source-muted": "ΎΕ▒",
    },

    "battery": {
        "bat": "BAT0",
        "adapter": "DC",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "max-length": 30,
        "format": "{icon} {capacity}% ",
        "format-warning": "{icon} {capacity}% ",
        "format-critical": "{icon} {capacity}% ",
        "format-charging": "<span font-family='Font Awesome 6 Free'>ΎΔπ</span> {capacity}%",
        "format-plugged": "Ύχμ",
        "format-alt": "{icon} {time}",
        "format-full": "Ύχμ",
        "format-icons": [
            "≤▒Λκ",
            "≤▒Λλ",
            "≤▒Λμ"
        ]
    },
    "custom/weather": {
        "exec": "python3 ~/.config/waybar/scripts/weather.py",
        "restart-interval": 300,
        "return-type": "json"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "swaylock",
        "format": "ΎΑμ"
    },
    "custom/spotify": {
        "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "ΎΗ╝ {}",
        "max-length": 30,
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-double-click-right": "playerctl next",
        "on-scroll-down": "playerctl previous"
    },
    "custom/power-menu": {
        "format": " έΠ╗ ",
        "on-click": "bash ~/.config/waybar/scripts/power-menu/powermenu.sh &"
    },
    "custom/launcher": {
        "format": "ΎΝΔ",
        "on-click": "sh .config/rofi/launchers/type-2/launcher.sh --style-2"
    }
}
