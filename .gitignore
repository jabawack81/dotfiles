.DS_Store
.config/btop/btop.log
# Claude settings (local)
settings.local.json
# Backup files
backups/
# Environment variables (contains sensitive data)
.env
# Private config example (template only)
private-config-example/

# Hyprland cache and fonts (generated locally)
common/hypr/.cache/
common/hypr/Fonts/
kyrios/hypr/.cache/
kyrios/hypr/Fonts/
shinkiro/hypr/.cache/
shinkiro/hypr/Fonts/

# Ansible check output (may contain private config values)
ansible-check.txt

# Neovim generated files
common/nvim/.neoconf.json
# Private neovim config (work-specific, symlinked from private-config)
common/nvim/lua/private/
common/nvim/lua/private

# EWW binary (installed via pacman/AUR)
common/bin/eww

# Opencode runtime-generated files (auto-created when plugins are configured)
common/opencode/package.json
common/opencode/package-lock.json
common/opencode/bun.lock
common/opencode/node_modules/
